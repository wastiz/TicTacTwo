@page
@model WebApp.Pages.LoadGame
@{
    ViewData["Title"] = "Load Game";
    ViewData["css-page"] = "load-game.css";
    ViewData["Username"] = $"Welcome back, {Model.Username}";
}

<main role="main" class="pb-3">
    <div class="container h-100">
        <div class="row h-100">
            <div class="col-12 col-sm-12 col-md-4 mt-5">
                <form method="post" id="gameForm">
                    <h1>Select Game Session:</h1>
                    <div class="load-game-container overflow-auto p-3" style="max-height: 400px; border: 1px solid #ddd; border-radius: 5px;">
                        @foreach (var sessionDto in Model.Games)
                        {
                        <div class="session-item d-flex align-items-center justify-content-between w-100 mb-3">
                            <div>
                                <input type="radio" class="btn-check" asp-for="SessionId"
                                       id="game-@sessionDto.SessionId" value="@sessionDto.SessionId" autocomplete="off">
                                <label class="btn btn-outline-primary btn-sm" for="game-@sessionDto.SessionId">@sessionDto.SessionName</label>
                            </div>
                            <button type="button" class="btn btn-danger btn-sm delete-session" data-session-id="@sessionDto.SessionId">
                                Delete
                            </button>
                        </div>
                        }
                    </div>

                    <div class="col-12 mt-5">
                        <button type="submit" class="btn btn-primary w-100">Start Game</button>
                    </div>
                </form>
            </div>

            <!-- Блок с анимацией -->
            <div class="col-12 col-sm-12 col-md-8 col-lg-8 d-flex align-items-center justify-content-center">
                <img src="img/animation.gif" width="400" height="400" alt="animation" id="home-animation">
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <script>
    document.querySelectorAll('.delete-session').forEach(button => {
        button.addEventListener('click', async () => {
            if (confirm("Are you sure you want to delete this session?")) {
                try {
                    const sessionId = button.getAttribute('data-session-id');
                    const response = await fetch("/LoadGame?handler=Delete", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ sessionId })
                    });

                    if (response.ok) {
                        alert("Session deleted successfully!");
                        location.reload();
                    } else {
                        alert("Failed to delete the session.");
                    }
                } catch (error) {
                    console.error("Error deleting session:", error);
                    alert("An error occurred while deleting the session.");
                }
            }
        });
    });
</script>
}
