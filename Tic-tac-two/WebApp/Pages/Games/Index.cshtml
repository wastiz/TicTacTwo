@page
@model WebApp.Pages_Games.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-page="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.GameSessionDB[0].GameState)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.GameSessionDB[0].Player1)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.GameSessionDB[0].Player2)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.GameSessionDB[0].GameMode)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.GameSessionDB[0].GamePassword)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.GameSessionDB) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.GameState.Id)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Player1.Id)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Player2.Id)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.GameMode)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.GamePassword)
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-page="./Details" asp-route-id="@item.Id">Details</a> |
                <a asp-page="./Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
