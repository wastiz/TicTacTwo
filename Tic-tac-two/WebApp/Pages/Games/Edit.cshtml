@page
@model WebApp.Pages_Games.EditModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>GameSessionDB</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="GameSessionDB.Id" />
            <div class="form-group">
                
                <label asp-for="GameSessionDB.GameStateId" class="control-label"></label>
                <select asp-for="GameSessionDB.GameStateId" class="form-control" asp-items="ViewBag.GameStateId"></select>
                <span asp-validation-for="GameSessionDB.GameStateId" class="text-danger"></span>
            </div>
            <div class="form-group">
                
                <label asp-for="GameSessionDB.Player1Id" class="control-label"></label>
                <select asp-for="GameSessionDB.Player1Id" class="form-control" asp-items="ViewBag.Player1Id"></select>
                <span asp-validation-for="GameSessionDB.Player1Id" class="text-danger"></span>
            </div>
            <div class="form-group">
                
                <label asp-for="GameSessionDB.Player2Id" class="control-label"></label>
                <select asp-for="GameSessionDB.Player2Id" class="form-control" asp-items="ViewBag.Player2Id"></select>
                <span asp-validation-for="GameSessionDB.Player2Id" class="text-danger"></span>
            </div>
            <div class="form-group">
                
                <label asp-for="GameSessionDB.GameMode" class="control-label"></label>
                <input asp-for="GameSessionDB.GameMode" class="form-control" />
                <span asp-validation-for="GameSessionDB.GameMode" class="text-danger"></span>
            </div>
            <div class="form-group">
                
                <label asp-for="GameSessionDB.GamePassword" class="control-label"></label>
                <input asp-for="GameSessionDB.GamePassword" class="form-control" />
                <span asp-validation-for="GameSessionDB.GamePassword" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
