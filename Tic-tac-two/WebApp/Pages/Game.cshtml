@page
@model WebApp.Pages.Game

<div class="container mt-4">
    <h1 class="mb-5">Tic-Tac-Two</h1>
    <div class="row">
        <div class="col-12">
            <form method="post">
                <div class="d-flex flex-wrap" style="width:@(Model.GridWidth * 80)px">
                    @for (int i = 0; i < Model.GridHeight; i++)
                    {
                    for (int j = 0; j < Model.GridWidth; j++)
                    {
                    <button type="submit" name="row" value="@i" formaction="/TicTacToe?col=@j"
                            class="btn btn-outline-primary border"
                            style="width: 80px; height: 80px; font-size: 24px;">
                        @if (@Model.Grid[i, j] == 1)
                        {
                            @:X
                        } else if (@Model.Grid[i, j] == 2)
                        {
                            @:O
                        }
                        else
                        {
                            @:
                        }
                    </button>
                    }
                    }
                </div>
            </form>
        </div>
    </div>
</div>