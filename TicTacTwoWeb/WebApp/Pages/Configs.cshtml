@page
@model WebApp.Pages.Configs

@{
    ViewData["Title"] = "Configurations";
    ViewData["Username"] = $"Welcome back, {Model.Username}";
}

<main role="main" class="pb-3">
    <div class="container py-5">
        <div class="row h-100">
            <!-- Column for displaying configurations -->
            <div class="col-md-6 mb-3">
                <h3>Available Configurations</h3>
                <ul class="list-group">
                    @foreach (var config in Model.gameConfigs)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <strong>@config.ConfigName</strong>
                            <div class="d-flex flex-row gap-3">
                                <button class="btn btn-info btn-sm text-white" onclick="openEditModal('@config.ConfigId')">View</button>
                                <button class="btn btn-danger btn-sm btn-delete" data-config-id="@config.ConfigId">Delete</button>
                            </div>
                        </li>
                    }
                </ul>
            </div>

            <!-- new conf -->
            <div class="col-md-6">
                <h3>Create New Configuration</h3>
                <form id="createForm">
                    <div class="mb-3">
                        <label for="name" class="form-label">Configuration Name</label>
                        <input type="text" class="form-control" id="name" name="name" required />
                    </div>
                    <div class="mb-3">
                        <label for="boardSizeWidth" class="form-label">Board Width</label>
                        <input type="number" class="form-control" id="boardSizeWidth" name="boardSizeWidth" value="5" required max="10" />
                    </div>
                    <div class="mb-3">
                        <label for="boardSizeHeight" class="form-label">Board Height</label>
                        <input type="number" class="form-control" id="boardSizeHeight" name="boardSizeHeight" value="5" required max="10" />
                    </div>
                    <div class="mb-3">
                        <label for="winCondition" class="form-label">Win Condition</label>
                        <input type="number" class="form-control" id="winCondition" name="winCondition" value="3" required />
                    </div>
                    <div class="mb-3">
                        <label for="optionsAfterNMoves" class="form-label">Options After N Moves</label>
                        <input type="number" class="form-control" id="optionsAfterNMoves" name="optionsAfterNMoves" value="2" required />
                    </div>
                    <div class="mb-3">
                        <label for="chipsCount" class="form-label">Chips Count</label>
                        <input type="number" class="form-control" id="chipsCount" name="chipsCount" value="4" required />
                    </div>
                    <button type="button" class="btn btn-primary" onclick="createConfiguration()">Create Configuration</button>
                </form>
            </div>
        </div>
    </div>

    <!-- Modal for editing configuration -->
    <div class="modal fade" id="editModal" tabindex="-1" aria-labelledby="editModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="editModalLabel">Edit Configuration</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="editForm">
                        <input type="hidden" id="editConfigId" name="configId" />
                        <div class="mb-3">
                            <label for="editName" class="form-label">Configuration Name</label>
                            <input type="text" class="form-control" id="editName" name="name" required />
                        </div>
                        <div class="mb-3">
                            <label for="editBoardSizeWidth" class="form-label">Board Width</label>
                            <input type="number" class="form-control" id="editBoardSizeWidth" name="boardSizeWidth" required max="10" />
                        </div>
                        <div class="mb-3">
                            <label for="editBoardSizeHeight" class="form-label">Board Height</label>
                            <input type="number" class="form-control" id="editBoardSizeHeight" name="boardSizeHeight" required max="10" />
                        </div>
                        <div class="mb-3">
                            <label for="editWinCondition" class="form-label">Win Condition</label>
                            <input type="number" class="form-control" id="editWinCondition" name="winCondition" required />
                        </div>
                        <div class="mb-3">
                            <label for="editOptionsAfterNMoves" class="form-label">Options After N Moves</label>
                            <input type="number" class="form-control" id="editOptionsAfterNMoves" name="optionsAfterNMoves" required />
                        </div>
                        <div class="mb-3">
                            <label for="editChipsCount" class="form-label">Chips Count</label>
                            <input type="number" class="form-control" id="editChipsCount" name="chipsCount" required />
                        </div>
                        <button type="button" class="btn btn-primary" onclick="updateConfiguration()">Save Changes</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
    
    
</main>

@section Scripts {
    <script>
        async function openEditModal(configId) {
            try {
                const response = await fetch(`/Configs?handler=GetConfig&configId=${configId}`);

                if (!response.ok) {
                    throw new Error("Failed to fetch configuration");
                }

                const data = await response.json();

                document.getElementById('editConfigId').value = configId;
                document.getElementById('editName').value = data.name;
                document.getElementById('editBoardSizeWidth').value = data.boardSizeWidth;
                document.getElementById('editBoardSizeHeight').value = data.boardSizeHeight;
                document.getElementById('editWinCondition').value = data.winCondition;
                document.getElementById('editOptionsAfterNMoves').value = data.optionsAfterNMoves;
                document.getElementById('editChipsCount').value = data.chipsCount;

        
                $('#editModal').modal('show');
            } catch (error) {
                console.error("Error fetching configuration:", error);
                alert("Failed to load configuration.");
            }
        }


        async function createConfiguration() {
            const formData = new FormData(document.getElementById("createForm"));
            const data = Object.fromEntries(formData.entries());

            const response = await fetch("/Configs?handler=Create", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(data)
            });

            if (response.ok) {
                alert("Configuration created successfully!");
                location.reload();
            } else {
                alert("Failed to create configuration!");
            }
        }

        async function updateConfiguration() {
            const formData = new FormData(document.getElementById("editForm"));
            const data = Object.fromEntries(formData.entries());

            const response = await fetch("/Configs?handler=Update", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(data)
            });

            if (response.ok) {
                alert("Configuration updated successfully!");
                location.reload();
            } else {
                alert("Failed to update configuration!");
            }
        }

        document.querySelectorAll(".btn-delete").forEach(btn => {
            btn.addEventListener("click", async function () {
                const configId = btn.getAttribute("data-config-id");

                const response = await fetch("/Configs?handler=Delete", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ configId })
                });

                if (response.ok) {
                    alert("Configuration deleted successfully!");
                    location.reload();
                } else {
                    alert("Failed to delete configuration!");
                }
            });
        });
        
    </script>
}